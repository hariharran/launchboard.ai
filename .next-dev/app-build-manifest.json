      "static/chunks/app/(app)/dashboard/page.js"
    ],
    "/(app)/projects/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/projects/page.js"
    ],
    "/(app)/generator/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/generator/page.js"
    ],
    "/api/ai/generate/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/ai/generate/route.js"
    ],
    "/api/projects/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/projects/route.js"
    ],
